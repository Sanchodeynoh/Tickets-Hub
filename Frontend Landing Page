<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TICKETS HUB - BTS ARIRANG Kuala Lumpur</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'army-purple': '#6B46C1',
            'army-light': '#A78BFA',
            'army-silver': '#E5E7EB',
            'army-black': '#0B0B0B'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-army-black text-army-silver font-sans">
  <!-- Navbar -->
  <nav class="border-b border-army-purple/30">
    <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-army-purple">TICKETS HUB</h1>
      <div class="flex gap-4 text-sm">
        <button class="hover:text-army-purple">Login</button>
        <button class="hover:text-army-purple">Cart <span id="cart-count" class="bg-army-purple px-2 py-0.5 rounded-full">0</span></button>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 py-16 text-center">
    <h2 class="text-4xl md:text-6xl font-bold mb-4">Resale Marketplace</h2>
    <p class="text-army-silver/70 mb-8">BTS • EXO • THE WEEKND • Verified Fan Resales</p>
    <div class="w-24 h-1 bg-army-purple mx-auto"></div>
  </section>

  <!-- Events Grid -->
  <section class="max-w-7xl mx-auto px-4 pb-20">
    <h3 class="text-2xl font-bold mb-8">Upcoming Events</h3>
    <div class="grid md:grid-cols-3 gap-6">
      
      <!-- BTS Card -->
      <div class="bg-army-black border-army-purple/30 rounded-lg overflow-hidden hover:border-army-purple transition">
        <div class="h-48 bg-gradient-to-br from-army-purple to-army-light flex items-center justify-center">
          <span class="text-3xl font-bold">BTS</span>
        </div>
        <div class="p-6">
          <h4 class="text-xl font-bold mb-2">BTS WORLD TOUR ARIRANG</h4>
          <p class="text-sm text-army-silver/70 mb-1">TM STADIUM NASIONAL, Kuala Lumpur</p>
          <p class="text-sm text-army-silver/70 mb-4">Dec 12-13, 2026 • Sat + Sun</p>
          <p class="text-xs text-army-light mb-4">Presale tickets • Multiple categories</p>
          <button onclick="openEvent('bts-arirang')" class="w-full bg-army-purple hover:bg-army-light text-white font-semibold py-3 rounded-lg transition">
            Buy Now
          </button>
        </div>
      </div>

      <!-- EXO Card -->
      <div class="bg-army-black border-army-purple/30 rounded-lg overflow-hidden hover:border-army-purple transition">
        <div class="h-48 bg-gradient-to-br from-gray-700 to-army-black flex items-center justify-center">
          <span class="text-3xl font-bold">EXO</span>
        </div>
        <div class="p-6">
          <h4 class="text-xl font-bold mb-2">EXO World Tour</h4>
          <p class="text-sm text-army-silver/70 mb-1">Venue TBA</p>
          <p class="text-sm text-army-silver/70 mb-4">Date TBA</p>
          <p class="text-xs text-army-light mb-4">Notify when listed</p>
          <button disabled class="w-full bg-gray-700 text-army-silver/50 font-semibold py-3 rounded-lg cursor-not-allowed">
            Coming Soon
          </button>
        </div>
      </div>

      <!-- The Weeknd Card -->
      <div class="bg-army-black border-army-purple/30 rounded-lg overflow-hidden hover:border-army-purple transition">
        <div class="h-48 bg-gradient-to-br from-red-900 to-army-black flex items-center justify-center">
          <span class="text-3xl font-bold">THE WEEKND</span>
        </div>
        <div class="p-6">
          <h4 class="text-xl font-bold mb-2">After Hours Tour</h4>
          <p class="text-sm text-army-silver/70 mb-1">Venue TBA</p>
          <p class="text-sm text-army-silver/70 mb-4">Date TBA</p>
          <p class="text-xs text-army-light mb-4">Notify when listed</p>
          <button disabled class="w-full bg-gray-700 text-army-silver/50 font-semibold py-3 rounded-lg cursor-not-allowed">
            Coming Soon
          </button>
        </div>
      </div>

    </div>
  </section>

  <!-- Event Modal - Step 2 will make this dynamic -->
  <div id="event-modal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center p-4 z-50">
    <div class="bg-army-black border-army-purple rounded-lg max-w-2xl w-full p-6">
      <h4 class="text-2xl font-bold mb-4">Select Tickets - BTS ARIRANG</h4>
      <p class="text-sm text-army-silver/70 mb-6">TM STADIUM NASIONAL • Dec 12-13, 2026</p>
      
      <div class="space-y-4 mb-6">
        <div class="flex justify-between items-center border-army-purple/30 p-4 rounded">
          <div>
            <p class="font-semibold">VIP Soundcheck</p>
            <p class="text-xs text-army-silver/70">Limited quantity</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="font-bold">$280</span>
            <input type="number" min="0" max="4" value="0" class="w-16 bg-army-black border-army-purple/50 rounded px-2 py-1 text-center" data-price="280">
          </div>
        </div>
        <div class="flex justify-between items-center border-army-purple/30 p-4 rounded">
          <div>
            <p class="font-semibold">GA Floor</p>
            <p class="text-xs text-army-silver/70">Standing</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="font-bold">$150</span>
            <input type="number" min="0" max="6" value="0" class="w-16 bg-army-black border-army-purple/50 rounded px-2 py-1 text-center" data-price="150">
          </div>
        </div>
      </div>

      <div class="flex gap-3">
        <button onclick="closeModal()" class="flex-1 border-army-purple py-3 rounded-lg hover:bg-army-purple/20">Cancel</button>
        <button onclick="proceedToCheckout()" class="flex-1 bg-army-purple hover:bg-army-light text-white font-semibold py-3 rounded-lg">Add to Cart</button>
      </div>
    </div>
  </div>

  <script src="script.js"></script>
</body>
</html>